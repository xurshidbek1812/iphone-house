generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id               Int               @id @default(autoincrement())
  fullName         String
  username         String            @unique
  password         String
  role             String            @default("ADMIN")
  createdAt        DateTime          @default(now())
  phone            String?
  cashTransactions CashTransaction[]
  inventoryActs    InventoryAct[]
  orders           Order[]
  partnerLedgers   PartnerLedger[]
  payments         Payment[]
  Return           Return[]
  stockMovements   StockMovement[]
  transactions     Transaction[]
}

model Customer {
  id                Int                @id @default(autoincrement())
  pinfl             String             @unique
  isBlacklisted     Boolean            @default(false)
  bonusBalance      Decimal            @default(0)
  createdAt         DateTime           @default(now())
  dob               DateTime
  firstName         String
  gender            String
  lastName          String
  middleName        String?
  note              String?
  blacklistRequests BlacklistRequest[]
  address           CustomerAddress?
  document          CustomerDocument?
  job               CustomerJob?
  phones            CustomerPhone[]
  orders            Order[]
  returns           Return[]
}

model BlacklistRequest {
  id            Int      @id @default(autoincrement())
  customerId    Int
  type          String
  reason        String
  requesterName String
  approverName  String?
  status        String   @default("Jarayonda")
  createdAt     DateTime @default(now())
  customer      Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model CustomerDocument {
  id         Int      @id @default(autoincrement())
  customerId Int      @unique
  type       String
  series     String
  number     String
  givenDate  DateTime
  expiryDate DateTime
  givenBy    String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model CustomerAddress {
  id         Int      @id @default(autoincrement())
  customerId Int      @unique
  regionId   Int
  districtId Int
  street     String?
  landmark   String?
  mfy        String?
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  district   District @relation(fields: [districtId], references: [id])
  region     Region   @relation(fields: [regionId], references: [id])
}

model CustomerPhone {
  id         Int      @id @default(autoincrement())
  customerId Int
  name       String
  phone      String
  isMain     Boolean  @default(false)
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model CustomerJob {
  id          Int      @id @default(autoincrement())
  customerId  Int      @unique
  type        String
  companyName String?
  position    String?
  source      String?
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model Region {
  id        Int               @id @default(autoincrement())
  name      String
  addresses CustomerAddress[]
  districts District[]
}

model District {
  id        Int               @id @default(autoincrement())
  name      String
  regionId  Int
  addresses CustomerAddress[]
  region    Region            @relation(fields: [regionId], references: [id])
}

model Category {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())
}

model Product {
  id                  Int                   @id @default(autoincrement())
  name                String
  createdAt           DateTime              @default(now())
  buyPrice            Float                 @default(0)
  customId            Int                   @unique
  quantity            Float                 @default(0)
  salePrice           Float                 @default(0)
  unit                String                @default("Dona")
  category            String                @default("-")
  buyCurrency         String                @default("USD")
  saleCurrency        String                @default("UZS")
  normalizedName      String?               @unique
  inventoryItems      InventoryItem[]
  orderItems          OrderItem[]
  batches             ProductBatch[]
  returnItems         ReturnItem[]
  stockMovements      StockMovement[]
  SupplierInvoiceItem SupplierInvoiceItem[]
}

model ProductBatch {
  id                    Int                        @id @default(autoincrement())
  initialQty            Float
  quantity              Float
  buyPrice              Float
  buyCurrency           String                     @default("USD")
  createdAt             DateTime                   @default(now())
  productId             Int
  isArchived            Boolean                    @default(false)
  invoiceNumber         String?
  supplierName          String?
  salePrice             Float?
  note                  String?
  reservedQty           Float                      @default(0)
  supplierId            Int?
  supplierInvoiceId     Int?
  supplierInvoiceItemId Int?
  allocations           OrderItemBatchAllocation[]
  product               Product                    @relation(fields: [productId], references: [id], onDelete: Cascade)
  supplier              Supplier?                  @relation(fields: [supplierId], references: [id])
  supplierInvoice       SupplierInvoice?           @relation(fields: [supplierInvoiceId], references: [id])
  supplierInvoiceItem   SupplierInvoiceItem?       @relation(fields: [supplierInvoiceItemId], references: [id])
  returnItems           ReturnItem[]
  stockMovements        StockMovement[]

  @@index([productId])
  @@index([supplierId])
  @@index([supplierInvoiceId])
}

model StockMovement {
  id         Int           @id @default(autoincrement())
  productId  Int
  batchId    Int?
  type       String
  quantity   Float
  unitCost   Decimal?
  unitPrice  Decimal?
  sourceType String
  sourceId   Int?
  note       String?
  createdAt  DateTime      @default(now())
  userId     Int?
  batch      ProductBatch? @relation(fields: [batchId], references: [id])
  product    Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  user       User?         @relation(fields: [userId], references: [id])

  @@index([productId])
  @@index([batchId])
  @@index([sourceType, sourceId])
  @@index([createdAt])
}

model Supplier {
  id        Int               @id @default(autoincrement())
  name      String
  phone     String?
  address   String?
  createdAt DateTime          @default(now())
  customId  String?
  note      String?
  batches   ProductBatch[]
  invoices  SupplierInvoice[]
}

model SupplierInvoice {
  id            Int                   @id @default(autoincrement())
  invoiceNumber String
  date          DateTime              @default(now())
  supplierName  String?
  totalSum      Decimal               @default(0)
  exchangeRate  Decimal               @default(12500)
  status        String                @default("Jarayonda")
  userName      String?
  createdAt     DateTime              @default(now())
  currency      String                @default("USD")
  note          String?
  supplierId    Int?
  batches       ProductBatch[]
  supplier      Supplier?             @relation(fields: [supplierId], references: [id])
  items         SupplierInvoiceItem[]

  @@index([supplierId])
  @@index([invoiceNumber])
}

model SupplierInvoiceItem {
  id                Int             @id @default(autoincrement())
  supplierInvoiceId Int
  productId         Int
  customId          Int?
  name              String
  count             Float
  price             Decimal
  salePrice         Decimal
  currency          String          @default("UZS")
  markup            Float?
  total             Decimal
  batches           ProductBatch[]
  product           Product         @relation(fields: [productId], references: [id])
  invoice           SupplierInvoice @relation(fields: [supplierInvoiceId], references: [id], onDelete: Cascade)

  @@index([supplierInvoiceId])
  @@index([productId])
}

model Partner {
  id              Int             @id @default(autoincrement())
  name            String
  phone           String?
  address         String?
  note            String?
  balanceSnapshot Decimal         @default(0)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  orders          Order[]
  ledgerEntries   PartnerLedger[]
  payments        Payment[]
  Return          Return[]
}

model PartnerLedger {
  id         Int      @id @default(autoincrement())
  partnerId  Int
  type       String
  amount     Decimal
  currency   String   @default("UZS")
  sourceType String
  sourceId   Int?
  note       String?
  createdAt  DateTime @default(now())
  userId     Int?
  partner    Partner  @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  user       User?    @relation(fields: [userId], references: [id])

  @@index([partnerId])
  @@index([sourceType, sourceId])
  @@index([createdAt])
}

model Order {
  id             Int         @id @default(autoincrement())
  orderNumber    String      @unique
  orderType      String
  status         String      @default("COMPLETED")
  customerId     Int?
  partnerId      Int?
  userId         Int
  subtotal       Decimal
  discountAmount Decimal     @default(0)
  totalAmount    Decimal
  paidAmount     Decimal     @default(0)
  dueAmount      Decimal     @default(0)
  note           String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  customer       Customer?   @relation(fields: [customerId], references: [id])
  partner        Partner?    @relation(fields: [partnerId], references: [id])
  user           User        @relation(fields: [userId], references: [id])
  items          OrderItem[]
  payments       Payment[]
  returns        Return[]

  @@index([customerId])
  @@index([partnerId])
  @@index([userId])
  @@index([createdAt])
}

model OrderItem {
  id             Int                        @id @default(autoincrement())
  orderId        Int
  productId      Int
  quantity       Float
  unitPrice      Decimal
  discountAmount Decimal                    @default(0)
  totalAmount    Decimal
  order          Order                      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product        Product                    @relation(fields: [productId], references: [id])
  allocations    OrderItemBatchAllocation[]

  @@index([orderId])
  @@index([productId])
}

model OrderItemBatchAllocation {
  id          Int          @id @default(autoincrement())
  orderItemId Int
  batchId     Int
  quantity    Float
  unitCost    Decimal?
  unitPrice   Decimal?
  batch       ProductBatch @relation(fields: [batchId], references: [id])
  orderItem   OrderItem    @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@index([orderItemId])
  @@index([batchId])
}

model Cashbox {
  id                 Int               @id @default(autoincrement())
  name               String            @unique
  balance            Decimal           @default(0)
  currency           String            @default("UZS")
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  cashTransactions   CashTransaction[]
  payments           Payment[]
  legacyTransactions Transaction[]     @relation("LegacyCashboxTransactions")
}

model Payment {
  id              Int              @id @default(autoincrement())
  amount          Decimal
  cashboxId       Int?
  currency        String           @default("UZS")
  direction       String           @default("IN")
  method          String
  note            String?
  orderId         Int?
  paidAt          DateTime         @default(now())
  partnerId       Int?
  payerType       String
  status          String           @default("POSTED")
  userId          Int?
  cashTransaction CashTransaction?
  cashbox         Cashbox?         @relation(fields: [cashboxId], references: [id])
  order           Order?           @relation(fields: [orderId], references: [id])
  partner         Partner?         @relation(fields: [partnerId], references: [id])
  user            User?            @relation(fields: [userId], references: [id])

  @@index([orderId])
  @@index([partnerId])
  @@index([cashboxId])
  @@index([paidAt])
}

model Transaction {
  id            Int      @id @default(autoincrement())
  createdAt     DateTime @default(now())
  amount        Decimal
  currency      String   @default("UZS")
  type          String
  category      String?
  description   String?
  userId        Int
  cashboxId     Int?
  paymentMethod String   @default("NAQD")
  reason        String?
  referenceId   Int?
  cashbox       Cashbox? @relation("LegacyCashboxTransactions", fields: [cashboxId], references: [id])
  user          User     @relation(fields: [userId], references: [id])

  @@index([cashboxId])
  @@index([userId])
}

model CashTransaction {
  id         Int      @id @default(autoincrement())
  cashboxId  Int
  paymentId  Int?     @unique
  type       String
  sourceType String
  sourceId   Int?
  amount     Decimal
  currency   String   @default("UZS")
  note       String?
  createdAt  DateTime @default(now())
  userId     Int?
  cashbox    Cashbox  @relation(fields: [cashboxId], references: [id])
  payment    Payment? @relation(fields: [paymentId], references: [id])
  user       User?    @relation(fields: [userId], references: [id])

  @@index([cashboxId])
  @@index([sourceType, sourceId])
  @@index([createdAt])
}

model Return {
  id           Int          @id @default(autoincrement())
  orderId      Int?
  customerId   Int?
  partnerId    Int?
  userId       Int?
  status       String       @default("DRAFT")
  totalAmount  Decimal      @default(0)
  refundAmount Decimal      @default(0)
  reason       String?
  createdAt    DateTime     @default(now())
  customer     Customer?    @relation(fields: [customerId], references: [id])
  order        Order?       @relation(fields: [orderId], references: [id])
  partner      Partner?     @relation(fields: [partnerId], references: [id])
  user         User?        @relation(fields: [userId], references: [id])
  items        ReturnItem[]

  @@index([orderId])
  @@index([customerId])
  @@index([partnerId])
}

model ReturnItem {
  id          Int           @id @default(autoincrement())
  returnId    Int
  productId   Int
  batchId     Int?
  quantity    Float
  unitPrice   Decimal?
  totalAmount Decimal?
  batch       ProductBatch? @relation(fields: [batchId], references: [id])
  product     Product       @relation(fields: [productId], references: [id])
  return      Return        @relation(fields: [returnId], references: [id], onDelete: Cascade)

  @@index([returnId])
  @@index([productId])
  @@index([batchId])
}

model InventoryAct {
  id             Int             @id @default(autoincrement())
  date           DateTime        @default(now())
  totalDiff      Float           @default(0)
  isStockUpdated Boolean         @default(false)
  userId         Int?
  user           User?           @relation(fields: [userId], references: [id])
  items          InventoryItem[]

  @@index([date])
}

model InventoryItem {
  id             Int          @id @default(autoincrement())
  inventoryActId Int
  productId      Int
  systemQty      Float
  countedQty     Float
  diff           Float
  inventoryAct   InventoryAct @relation(fields: [inventoryActId], references: [id], onDelete: Cascade)
  product        Product      @relation(fields: [productId], references: [id])

  @@index([inventoryActId])
  @@index([productId])
}
