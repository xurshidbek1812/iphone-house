generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               Int               @id @default(autoincrement())
  fullName         String
  username         String            @unique
  password         String
  phone            String?
  role             String            @default("ADMIN")
  createdAt        DateTime          @default(now())

  orders           Order[]
  payments         Payment[]
  cashTransactions CashTransaction[]
  stockMovements   StockMovement[]
  partnerLedgers   PartnerLedger[]
  inventoryActs    InventoryAct[]
}

model Customer {
  id                Int                 @id @default(autoincrement())
  firstName         String
  lastName          String
  middleName        String?
  gender            String
  dob               DateTime
  pinfl             String              @unique
  note              String?

  document          CustomerDocument?
  address           CustomerAddress?
  phones            CustomerPhone[]
  job               CustomerJob?

  createdAt         DateTime            @default(now())

  orders            Order[]
  returns           Return[]

  isBlacklisted     Boolean             @default(false)
  bonusBalance      Decimal             @default(0)
  blacklistRequests BlacklistRequest[]
}

model BlacklistRequest {
  id            Int      @id @default(autoincrement())

  customerId    Int
  customer      Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  type          String
  reason        String

  requesterName String
  approverName  String?

  status        String   @default("Jarayonda")
  createdAt     DateTime @default(now())
}

model CustomerDocument {
  id         Int      @id @default(autoincrement())
  customerId Int      @unique
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  type       String
  series     String
  number     String
  givenDate  DateTime
  expiryDate DateTime
  givenBy    String
}

model CustomerAddress {
  id         Int      @id @default(autoincrement())
  customerId Int      @unique
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  regionId   Int
  districtId Int

  region     Region   @relation(fields: [regionId], references: [id])
  district   District @relation(fields: [districtId], references: [id])

  mfy        String?
  street     String?
  landmark   String?
}

model CustomerPhone {
  id         Int      @id @default(autoincrement())
  customerId Int
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  name       String
  phone      String
  isMain     Boolean  @default(false)
}

model CustomerJob {
  id          Int      @id @default(autoincrement())
  customerId  Int      @unique
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  type        String
  companyName String?
  position    String?
  source      String?
}

model Region {
  id        Int        @id @default(autoincrement())
  name      String
  districts District[]
  addresses CustomerAddress[]
}

model District {
  id        Int              @id @default(autoincrement())
  name      String
  regionId  Int
  region    Region           @relation(fields: [regionId], references: [id])
  addresses CustomerAddress[]
}

model Category {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())
}

model Product {
  id               Int                         @id @default(autoincrement())
  customId         Int                         @unique
  name             String
  normalizedName   String?                     @unique
  category         String                      @default("-")
  unit             String                      @default("Dona")

  buyPrice         Float                       @default(0)
  salePrice        Float                       @default(0)

  quantity         Float                       @default(0)
  buyCurrency      String                      @default("USD")
  saleCurrency     String                      @default("UZS")

  createdAt        DateTime                    @default(now())

  batches          ProductBatch[]
  stockMovements   StockMovement[]
  orderItems       OrderItem[]
  inventoryItems   InventoryItem[]
  returnItems      ReturnItem[]
}

model ProductBatch {
  id                    Int                         @id @default(autoincrement())

  productId             Int
  product               Product                     @relation(fields: [productId], references: [id], onDelete: Cascade)

  supplierId            Int?
  supplier              Supplier?                   @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  supplierInvoiceId     Int?
  supplierInvoice       SupplierInvoice?            @relation(fields: [supplierInvoiceId], references: [id], onDelete: SetNull)

  supplierInvoiceItemId Int?                        @unique
  supplierInvoiceItem   SupplierInvoiceItem?        @relation(fields: [supplierInvoiceItemId], references: [id], onDelete: SetNull)

  initialQty            Float
  quantity              Float
  reservedQty           Float                       @default(0)

  buyPrice              Float
  salePrice             Float?
  buyCurrency           String                      @default("USD")

  supplierName          String?
  invoiceNumber         String?

  createdAt             DateTime                    @default(now())
  isArchived            Boolean                     @default(false)
  note                  String?

  allocations           OrderItemBatchAllocation[]
  stockMovements        StockMovement[]
  returnItems           ReturnItem[]

  @@index([productId])
  @@index([supplierId])
  @@index([supplierInvoiceId])
}

model StockMovement {
  id          Int           @id @default(autoincrement())

  productId   Int
  product     Product       @relation(fields: [productId], references: [id], onDelete: Cascade)

  batchId     Int?
  batch       ProductBatch? @relation(fields: [batchId], references: [id], onDelete: SetNull)

  type        String
  // IN, OUT, RETURN, ADJUSTMENT, RESERVE, RELEASE

  quantity    Float

  unitCost    Decimal?
  unitPrice   Decimal?

  sourceType  String
  // SUPPLIER_INVOICE, ORDER, RETURN, INVENTORY_ACT, MIGRATION

  sourceId    Int?

  note        String?
  createdAt   DateTime      @default(now())

  userId      Int?
  user        User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([batchId])
  @@index([sourceType, sourceId])
  @@index([createdAt])
}

model Supplier {
  id        Int              @id @default(autoincrement())
  customId  String?
  name      String
  phone     String?
  address   String?
  note      String?
  createdAt DateTime         @default(now())

  invoices  SupplierInvoice[]
  batches   ProductBatch[]
}

model SupplierInvoice {
  id            Int                   @id @default(autoincrement())

  supplierId    Int?
  supplier      Supplier?             @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  invoiceNumber String
  date          DateTime              @default(now())

  totalSum      Decimal               @default(0)
  exchangeRate  Decimal               @default(12500)
  currency      String                @default("USD")

  status        String                @default("Jarayonda")
  userName      String?
  note          String?

  createdAt     DateTime              @default(now())

  items         SupplierInvoiceItem[]
  batches       ProductBatch[]

  @@index([supplierId])
  @@index([invoiceNumber])
}

model SupplierInvoiceItem {
  id                Int               @id @default(autoincrement())

  supplierInvoiceId Int
  invoice           SupplierInvoice   @relation(fields: [supplierInvoiceId], references: [id], onDelete: Cascade)

  productId         Int
  product           Product           @relation(fields: [productId], references: [id], onDelete: Restrict)

  customId          Int?
  name              String
  count             Float
  price             Decimal
  salePrice         Decimal
  currency          String            @default("UZS")
  markup            Float?
  total             Decimal

  batch             ProductBatch?

  @@index([supplierInvoiceId])
  @@index([productId])
}

model Partner {
  id              Int             @id @default(autoincrement())
  name            String
  phone           String?
  address         String?
  note            String?
  balanceSnapshot Decimal         @default(0)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  orders          Order[]
  payments        Payment[]
  ledgerEntries   PartnerLedger[]
}

model PartnerLedger {
  id          Int       @id @default(autoincrement())

  partnerId    Int
  partner      Partner   @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  type         String
  // DEBIT, CREDIT

  amount       Decimal
  currency     String    @default("UZS")

  sourceType   String
  // ORDER, PAYMENT, RETURN, ADJUSTMENT, MIGRATION

  sourceId     Int?

  note         String?
  createdAt    DateTime  @default(now())

  userId       Int?
  user         User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([partnerId])
  @@index([sourceType, sourceId])
  @@index([createdAt])
}

model Order {
  id             Int         @id @default(autoincrement())
  orderNumber    String      @unique

  orderType      String
  // DIRECT, PARTNER

  status         String      @default("COMPLETED")
  // DRAFT, COMPLETED, CANCELLED, RETURNED

  customerId     Int?
  customer       Customer?   @relation(fields: [customerId], references: [id], onDelete: SetNull)

  partnerId      Int?
  partner        Partner?    @relation(fields: [partnerId], references: [id], onDelete: SetNull)

  userId         Int
  user           User        @relation(fields: [userId], references: [id], onDelete: Restrict)

  subtotal       Decimal
  discountAmount Decimal     @default(0)
  totalAmount    Decimal

  paidAmount     Decimal     @default(0)
  dueAmount      Decimal     @default(0)

  note           String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  items          OrderItem[]
  payments       Payment[]
  returns        Return[]

  @@index([customerId])
  @@index([partnerId])
  @@index([userId])
  @@index([createdAt])
}

model OrderItem {
  id             Int                         @id @default(autoincrement())

  orderId        Int
  order          Order                       @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId      Int
  product        Product                     @relation(fields: [productId], references: [id], onDelete: Restrict)

  quantity       Float
  unitPrice      Decimal
  discountAmount Decimal                     @default(0)
  totalAmount    Decimal

  allocations    OrderItemBatchAllocation[]

  @@index([orderId])
  @@index([productId])
}

model OrderItemBatchAllocation {
  id          Int         @id @default(autoincrement())

  orderItemId Int
  orderItem   OrderItem   @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  batchId     Int
  batch       ProductBatch @relation(fields: [batchId], references: [id], onDelete: Restrict)

  quantity    Float
  unitCost    Decimal?
  unitPrice   Decimal?

  @@index([orderItemId])
  @@index([batchId])
}

model Cashbox {
  id               Int               @id @default(autoincrement())
  name             String            @unique
  balance          Decimal           @default(0)
  currency         String            @default("UZS")
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  payments         Payment[]
  cashTransactions CashTransaction[]
}

model Payment {
  id               Int               @id @default(autoincrement())

  orderId          Int?
  order            Order?            @relation(fields: [orderId], references: [id], onDelete: SetNull)

  partnerId        Int?
  partner          Partner?          @relation(fields: [partnerId], references: [id], onDelete: SetNull)

  amount           Decimal
  currency         String            @default("UZS")

  method           String
  // CASH, CARD, BANK_TRANSFER

  payerType        String
  // CUSTOMER, PARTNER

  direction        String            @default("IN")
  // IN, OUT

  status           String            @default("POSTED")
  paidAt           DateTime          @default(now())

  cashboxId        Int?
  cashbox          Cashbox?          @relation(fields: [cashboxId], references: [id], onDelete: SetNull)

  userId           Int?
  user             User?             @relation(fields: [userId], references: [id], onDelete: SetNull)

  note             String?

  cashTransaction  CashTransaction?

  @@index([orderId])
  @@index([partnerId])
  @@index([cashboxId])
  @@index([paidAt])
}

model CashTransaction {
  id          Int       @id @default(autoincrement())

  cashboxId   Int
  cashbox     Cashbox   @relation(fields: [cashboxId], references: [id], onDelete: Restrict)

  paymentId   Int?      @unique
  payment     Payment?  @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  type        String
  // INCOME, EXPENSE

  sourceType  String
  // ORDER_PAYMENT, PARTNER_PAYMENT, REFUND, MANUAL_EXPENSE, MIGRATION

  sourceId    Int?

  amount      Decimal
  currency    String    @default("UZS")

  note        String?
  createdAt   DateTime  @default(now())

  userId      Int?
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([cashboxId])
  @@index([sourceType, sourceId])
  @@index([createdAt])
}

model Return {
  id            Int          @id @default(autoincrement())

  orderId        Int?
  order          Order?      @relation(fields: [orderId], references: [id], onDelete: SetNull)

  customerId     Int?
  customer       Customer?   @relation(fields: [customerId], references: [id], onDelete: SetNull)

  partnerId      Int?
  partner        Partner?    @relation(fields: [partnerId], references: [id], onDelete: SetNull)

  userId         Int?
  user           User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  status         String      @default("DRAFT")
  // DRAFT, POSTED, CANCELLED

  totalAmount    Decimal     @default(0)
  refundAmount   Decimal     @default(0)

  reason         String?
  createdAt      DateTime    @default(now())

  items          ReturnItem[]

  @@index([orderId])
  @@index([customerId])
  @@index([partnerId])
}

model ReturnItem {
  id           Int           @id @default(autoincrement())

  returnId      Int
  return        Return        @relation(fields: [returnId], references: [id], onDelete: Cascade)

  productId     Int
  product       Product       @relation(fields: [productId], references: [id], onDelete: Restrict)

  batchId       Int?
  batch         ProductBatch? @relation(fields: [batchId], references: [id], onDelete: SetNull)

  quantity      Float
  unitPrice     Decimal?
  totalAmount   Decimal?

  @@index([returnId])
  @@index([productId])
  @@index([batchId])
}

model InventoryAct {
  id             Int             @id @default(autoincrement())
  date           DateTime        @default(now())
  totalDiff      Float           @default(0)
  isStockUpdated Boolean         @default(false)

  userId         Int?
  user           User?           @relation(fields: [userId], references: [id], onDelete: SetNull)

  items          InventoryItem[]

  @@index([date])
}

model InventoryItem {
  id             Int           @id @default(autoincrement())

  inventoryActId Int
  inventoryAct   InventoryAct  @relation(fields: [inventoryActId], references: [id], onDelete: Cascade)

  productId      Int
  product        Product       @relation(fields: [productId], references: [id], onDelete: Restrict)

  systemQty      Float
  countedQty     Float
  diff           Float

  @@index([inventoryActId])
  @@index([productId])
}
