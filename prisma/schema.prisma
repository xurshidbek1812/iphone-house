generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  fullName  String
  username  String   @unique
  password  String
  phone     String?
  role      String   @default("ADMIN")
  createdAt DateTime @default(now())

  orders           Order[]
  contracts        Contract[]
  contractComments ContractComment[]
  payments         Payment[]
  cashTransactions CashTransaction[]
  transactions     Transaction[]
  stockMovements   StockMovement[]
  partnerLedgers   PartnerLedger[]
  inventoryActs    InventoryAct[]
  Return           Return[]
  notifications Notification[]
  permissions String[] @default([])
  cashboxTransactions CashboxTransaction[]
  createdExpenses  Expense[] @relation("ExpenseCreatedBy")
  approvedExpenses Expense[] @relation("ExpenseApprovedBy")
}

model Customer {
  id         Int      @id @default(autoincrement())
  firstName  String
  lastName   String
  middleName String?
  gender     String
  dob        DateTime
  pinfl      String   @unique
  note       String?

  document CustomerDocument?
  address  CustomerAddress?
  phones   CustomerPhone[]
  job      CustomerJob?

  createdAt DateTime @default(now())

  orders          Order[]
  contracts       Contract[]
  coBorrowerLinks ContractCoBorrower[]
  returns         Return[]

  isBlacklisted     Boolean            @default(false)
  bonusBalance      Decimal            @default(0)
  blacklistRequests BlacklistRequest[]
}

model BlacklistRequest {
  id Int @id @default(autoincrement())

  customerId Int
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  type   String
  reason String

  requesterName String
  approverName  String?

  status    String   @default("Jarayonda")
  createdAt DateTime @default(now())
}

model CustomerDocument {
  id         Int      @id @default(autoincrement())
  customerId Int      @unique
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  type       String
  series     String
  number     String
  givenDate  DateTime
  expiryDate DateTime
  givenBy    String
}

model CustomerAddress {
  id         Int      @id @default(autoincrement())
  customerId Int      @unique
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  regionId   Int
  districtId Int

  region   Region   @relation(fields: [regionId], references: [id])
  district District @relation(fields: [districtId], references: [id])

  mfy      String?
  street   String?
  landmark String?
}

model CustomerPhone {
  id         Int      @id @default(autoincrement())
  customerId Int
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  name   String
  phone  String
  isMain Boolean @default(false)
}

model CustomerJob {
  id         Int      @id @default(autoincrement())
  customerId Int      @unique
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  type        String
  companyName String?
  position    String?
  source      String?
}

model Region {
  id        Int               @id @default(autoincrement())
  name      String
  districts District[]
  addresses CustomerAddress[]
}

model District {
  id        Int               @id @default(autoincrement())
  name      String
  regionId  Int
  region    Region            @relation(fields: [regionId], references: [id])
  addresses CustomerAddress[]
}

model Category {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())
}

model Product {
  id             Int     @id @default(autoincrement())
  customId       Int     @unique
  name           String
  normalizedName String? @unique
  category       String  @default("-")
  unit           String  @default("Dona")

  buyPrice  Float @default(0)
  salePrice Float @default(0)

  quantity     Float  @default(0)
  buyCurrency  String @default("USD")
  saleCurrency String @default("UZS")

  createdAt DateTime @default(now())

  batches             ProductBatch[]
  stockMovements      StockMovement[]
  orderItems          OrderItem[]
  contractItems       ContractItem[]
  inventoryItems      InventoryItem[]
  returnItems         ReturnItem[]
  SupplierInvoiceItem SupplierInvoiceItem[]
}

model ProductBatch {
  id Int @id @default(autoincrement())

  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  supplierId Int?
  supplier   Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  supplierInvoiceId Int?
  supplierInvoice   SupplierInvoice? @relation(fields: [supplierInvoiceId], references: [id], onDelete: SetNull)

  supplierInvoiceItemId Int?
  supplierInvoiceItem   SupplierInvoiceItem? @relation(fields: [supplierInvoiceItemId], references: [id], onDelete: SetNull)

  initialQty  Float
  quantity    Float
  reservedQty Float @default(0)

  buyPrice    Float
  salePrice   Float?
  buyCurrency String @default("USD")

  supplierName  String?
  invoiceNumber String?

  createdAt  DateTime @default(now())
  isArchived Boolean  @default(false)
  note       String?

  allocations         OrderItemBatchAllocation[]
  contractAllocations ContractItemBatchAllocation[]
  stockMovements      StockMovement[]
  returnItems         ReturnItem[]

  @@index([productId])
  @@index([supplierId])
  @@index([supplierInvoiceId])
}

model StockMovement {
  id Int @id @default(autoincrement())

  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  batchId Int?
  batch   ProductBatch? @relation(fields: [batchId], references: [id], onDelete: SetNull)

  type String
  // IN, OUT, RETURN, ADJUSTMENT, RESERVE, RELEASE

  quantity Float

  unitCost  Decimal?
  unitPrice Decimal?

  sourceType String
  // SUPPLIER_INVOICE, ORDER, CONTRACT, RETURN, INVENTORY_ACT, MIGRATION

  sourceId Int?

  note      String?
  createdAt DateTime @default(now())

  userId Int?
  user   User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([batchId])
  @@index([sourceType, sourceId])
  @@index([createdAt])
}

model Supplier {
  id        Int      @id @default(autoincrement())
  customId  String?
  name      String
  phone     String?
  address   String?
  note      String?
  createdAt DateTime @default(now())

  invoices SupplierInvoice[]
  batches  ProductBatch[]
}

model SupplierInvoice {
  id Int @id @default(autoincrement())

  supplierId   Int?
  supplierName String?
  supplier     Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  invoiceNumber String
  date          DateTime @default(now())

  totalSum     Decimal @default(0)
  exchangeRate Decimal @default(12500)
  currency     String  @default("USD")

  status   String  @default("Jarayonda")
  userName String?
  note     String?

  createdAt DateTime @default(now())

  items   SupplierInvoiceItem[]
  batches ProductBatch[]

  @@index([supplierId])
  @@index([invoiceNumber])
}

model SupplierInvoiceItem {
  id Int @id @default(autoincrement())

  supplierInvoiceId Int
  invoice           SupplierInvoice @relation(fields: [supplierInvoiceId], references: [id], onDelete: Cascade)

  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  customId  Int?
  name      String
  count     Float
  price     Decimal
  salePrice Decimal
  currency  String  @default("UZS")
  markup    Float?
  total     Decimal

  batches ProductBatch[]

  @@index([supplierInvoiceId])
  @@index([productId])
}

model Partner {
  id              Int      @id @default(autoincrement())
  name            String
  phone           String?
  address         String?
  note            String?
  balanceSnapshot Decimal  @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  orders        Order[]
  payments      Payment[]
  ledgerEntries PartnerLedger[]
  Return        Return[]
}

model PartnerLedger {
  id Int @id @default(autoincrement())

  partnerId Int
  partner   Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  type String
  // DEBIT, CREDIT

  amount   Decimal
  currency String  @default("UZS")

  sourceType String
  // ORDER, PAYMENT, RETURN, ADJUSTMENT, MIGRATION

  sourceId Int?

  note      String?
  createdAt DateTime @default(now())

  userId Int?
  user   User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([partnerId])
  @@index([sourceType, sourceId])
  @@index([createdAt])
}

model Order {
  id          Int    @id @default(autoincrement())
  orderNumber String @unique

  orderType String
  // DIRECT, PARTNER

  status String @default("COMPLETED")
  // DRAFT, COMPLETED, CANCELLED, RETURNED

  customerId Int?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  partnerId Int?
  partner   Partner? @relation(fields: [partnerId], references: [id], onDelete: SetNull)

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Restrict)

  subtotal       Decimal
  discountAmount Decimal @default(0)
  totalAmount    Decimal

  paidAmount Decimal @default(0)
  dueAmount  Decimal @default(0)

  note       String?
  otherName  String?
  otherPhone String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  items    OrderItem[]
  payments Payment[]
  returns  Return[]

  @@index([customerId])
  @@index([partnerId])
  @@index([userId])
  @@index([createdAt])
}

model OrderItem {
  id Int @id @default(autoincrement())

  orderId Int
  order   Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  quantity       Float
  unitPrice      Decimal
  discountAmount Decimal @default(0)
  totalAmount    Decimal

  allocations OrderItemBatchAllocation[]

  @@index([orderId])
  @@index([productId])
}

model OrderItemBatchAllocation {
  id Int @id @default(autoincrement())

  orderItemId Int
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  batchId Int
  batch   ProductBatch @relation(fields: [batchId], references: [id], onDelete: Restrict)

  quantity  Float
  unitCost  Decimal?
  unitPrice Decimal?

  @@index([orderItemId])
  @@index([batchId])
}

model Contract {
  id Int @id @default(autoincrement())

  contractNumber String @unique

  status String @default("DRAFT")
  // DRAFT, COMPLETED, CANCELLED

  customerId Int
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Restrict)

  cashboxId Int
  cashbox   Cashbox @relation(fields: [cashboxId], references: [id], onDelete: Restrict)

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Restrict)

  totalAmount    Decimal
  prepayment     Decimal @default(0)
  debtAmount     Decimal @default(0)
  monthlyPayment Decimal @default(0)
  discountAmount Decimal @default(0)

  durationMonths Int @default(0)
  paymentDay     Int @default(1)

  note String?

  confirmedAt DateTime?
  cancelledAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items       ContractItem[]
  coBorrowers ContractCoBorrower[]
  schedules   ContractSchedule[]
  comments    ContractComment[]
  payments    Payment[]

  @@index([customerId])
  @@index([cashboxId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model ContractItem {
  id Int @id @default(autoincrement())

  contractId Int
  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  quantity    Float
  unitPrice   Decimal
  totalAmount Decimal

  allocations ContractItemBatchAllocation[]

  @@index([contractId])
  @@index([productId])
}

model ContractItemBatchAllocation {
  id Int @id @default(autoincrement())

  contractItemId Int
  contractItem   ContractItem @relation(fields: [contractItemId], references: [id], onDelete: Cascade)

  batchId Int
  batch   ProductBatch @relation(fields: [batchId], references: [id], onDelete: Restrict)

  quantity  Float
  unitCost  Decimal?
  unitPrice Decimal?

  @@index([contractItemId])
  @@index([batchId])
}

model ContractCoBorrower {
  id Int @id @default(autoincrement())

  contractId Int
  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  customerId Int
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())

  @@unique([contractId, customerId])
  @@index([contractId])
  @@index([customerId])
}

model ContractSchedule {
  id Int @id @default(autoincrement())

  contractId Int
  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  monthNumber Int
  date        DateTime
  amount      Decimal
  paid        Decimal  @default(0)

  status String @default("KUTILMOQDA")
  // KUTILMOQDA, TOLANDI, QISMAN_TOLANDI, KECIKDI

  createdAt DateTime @default(now())

  @@unique([contractId, monthNumber])
  @@index([contractId])
  @@index([date])
}

model ContractComment {
  id Int @id @default(autoincrement())

  contractId Int
  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  userId Int?
  user   User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  authorName String?
  text       String

  createdAt DateTime @default(now())

  @@index([contractId])
  @@index([userId])
  @@index([createdAt])
}

model Cashbox {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  balance   Decimal    @default(0)
  currency  String   @default("UZS")
  responsibleName String?
  isActive        Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contracts          Contract[]
  payments           Payment[]
  cashTransactions   CashTransaction[]
  legacyTransactions Transaction[]     @relation("LegacyCashboxTransactions")
  transactions       CashboxTransaction[]
  expenses Expense[]
}

model CashboxTransaction {
  id        Int      @id @default(autoincrement())
  cashboxId Int
  cashbox   Cashbox  @relation(fields: [cashboxId], references: [id], onDelete: Cascade)

  type      String   // DEPOSIT | WITHDRAW
  amount    Decimal
  note      String?
  createdAt DateTime @default(now())

  userId    Int?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  transferGroupId String?

  @@index([cashboxId])
  @@index([createdAt])
}

model Payment {
  id Int @id @default(autoincrement())

  orderId Int?
  order   Order? @relation(fields: [orderId], references: [id], onDelete: SetNull)

  partnerId Int?
  partner   Partner? @relation(fields: [partnerId], references: [id], onDelete: SetNull)

  contractId Int?
  contract   Contract? @relation(fields: [contractId], references: [id], onDelete: SetNull)

  amount   Decimal
  currency String  @default("UZS")

  method String
  // CASH, CARD, BANK_TRANSFER, CONTRACT

  payerType String
  // CUSTOMER, PARTNER, CONTRACT_ORG

  direction String @default("IN")
  // IN, OUT

  status String   @default("POSTED")
  paidAt DateTime @default(now())

  cashboxId Int?
  cashbox   Cashbox? @relation(fields: [cashboxId], references: [id], onDelete: SetNull)

  userId Int?
  user   User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  note String?

  cashTransaction CashTransaction?

  @@index([orderId])
  @@index([partnerId])
  @@index([contractId])
  @@index([cashboxId])
  @@index([paidAt])
}

model Transaction {
  id            Int      @id @default(autoincrement())
  type          String
  amount        Decimal
  currency      String   @default("UZS")
  paymentMethod String   @default("NAQD")
  category      String?
  reason        String?
  description   String?
  referenceId   Int?
  createdAt     DateTime @default(now())

  cashboxId Int?
  cashbox   Cashbox? @relation("LegacyCashboxTransactions", fields: [cashboxId], references: [id])

  userId Int
  user   User @relation(fields: [userId], references: [id])

  @@index([cashboxId])
  @@index([userId])
}

model CashTransaction {
  id Int @id @default(autoincrement())

  cashboxId Int
  cashbox   Cashbox @relation(fields: [cashboxId], references: [id], onDelete: Restrict)

  paymentId Int?     @unique
  payment   Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  type String
  // INCOME, EXPENSE

  sourceType String
  // ORDER_PAYMENT, CONTRACT_PAYMENT, PARTNER_PAYMENT, REFUND, MANUAL_EXPENSE, MIGRATION

  sourceId Int?

  amount   Decimal
  currency String  @default("UZS")

  note      String?
  createdAt DateTime @default(now())

  userId Int?
  user   User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([cashboxId])
  @@index([sourceType, sourceId])
  @@index([createdAt])
}

model Return {
  id Int @id @default(autoincrement())

  orderId Int?
  order   Order? @relation(fields: [orderId], references: [id], onDelete: SetNull)

  customerId Int?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  partnerId Int?
  partner   Partner? @relation(fields: [partnerId], references: [id], onDelete: SetNull)

  userId Int?
  user   User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  status String @default("DRAFT")
  // DRAFT, POSTED, CANCELLED

  totalAmount  Decimal @default(0)
  refundAmount Decimal @default(0)

  reason    String?
  createdAt DateTime @default(now())

  items ReturnItem[]

  @@index([orderId])
  @@index([customerId])
  @@index([partnerId])
}

model ReturnItem {
  id Int @id @default(autoincrement())

  returnId Int
  return   Return @relation(fields: [returnId], references: [id], onDelete: Cascade)

  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  batchId Int?
  batch   ProductBatch? @relation(fields: [batchId], references: [id], onDelete: SetNull)

  quantity    Float
  unitPrice   Decimal?
  totalAmount Decimal?

  @@index([returnId])
  @@index([productId])
  @@index([batchId])
}

model InventoryAct {
  id             Int      @id @default(autoincrement())
  date           DateTime @default(now())
  totalDiff      Float    @default(0)
  isStockUpdated Boolean  @default(false)

  userId Int?
  user   User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  items InventoryItem[]

  @@index([date])
}

model InventoryItem {
  id Int @id @default(autoincrement())

  inventoryActId Int
  inventoryAct   InventoryAct @relation(fields: [inventoryActId], references: [id], onDelete: Cascade)

  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  systemQty  Float
  countedQty Float
  diff       Float

  @@index([inventoryActId])
  @@index([productId])
}

model Notification {
  id Int @id @default(autoincrement())

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  type String
  // BLACKLIST, CONTRACT, ORDER, INVOICE

  title String
  message String?

  entityType String?
  // BLACKLIST_REQUEST, CONTRACT, ORDER, SUPPLIER_INVOICE

  entityId Int?

  status String?
  // Yuborildi, To'lov kutilmoqda, Jarayonda ...

  amount Decimal? @default(0)

  isRead Boolean @default(false)
  readAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, isRead])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model Expense {
  id           Int      @id @default(autoincrement())
  amount       Decimal  @default(0)
  note         String?
  expenseType  String?
  status       String   @default("Jarayonda")
  cashboxId    Int
  createdById  Int
  approvedById Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  approvedAt   DateTime?

  cashbox    Cashbox @relation(fields: [cashboxId], references: [id], onDelete: Restrict)
  createdBy  User    @relation("ExpenseCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  approvedBy User?   @relation("ExpenseApprovedBy", fields: [approvedById], references: [id], onDelete: Restrict)

  @@index([cashboxId])
  @@index([createdById])
  @@index([approvedById])
  @@index([status])
  @@index([createdAt])
}